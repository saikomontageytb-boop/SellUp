{
  "name": "sellup",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "worker:dev": "wrangler dev --config worker/wrangler.toml",
    "worker:deploy": "wrangler deploy --config worker/wrangler.toml",
    "db:init": "wrangler d1 execute sellup-db --file=worker/schema.sql",
    "db:init:remote": "wrangler d1 execute sellup-db --remote --file=worker/schema.sql"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "framer-motion": "^12.41.0",
    "lucide-react": "^1.21.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-router-dom": "^7.1.0",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260623.1",
    "@tailwindcss/vite": "4.1.17",
    "@types/node": "22.19.17",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.1",
    "tailwindcss": "4.1.17",
    "typescript": "5.9.3",
    "vite": "7.3.2",
    "wrangler": "^3.95.0"
  }
}
